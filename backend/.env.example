######## DOCKER COMPOSE #########
COMPOSE_PROFILES="qdrant_token_auth"

########### POSTGRESQL ############
POSTGRES_USER="admin_user"
POSTGRES_PASSWORD="your-secret-key"
POSTGRES_DB="production_db"

# Format: postgresql+asyncpg://user:password@host:port/dbname
POSTGRES_URL="postgresql+asyncpg://admin_user:your-secret-key=@localhost:5433/production_db"

########### FASTAPI ############
ALLOW_ORIGINS="http://localhost:5173"

########### JWT ############
JWT_SECRET_KEY="your-secret-key" # openssl rand -hex 32
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="30" 

########### QDRANT ############
QDRANT_HOST="localhost"
QDRANT_PORT="6333"
QDRANT_SSL="false"
QDRANT_COLLECTION_NAME="production_docs"

###### --- NO AUTH --- #######
# Add "qdrant_no_auth" to COMPOSE_PROFILES
 
###### --- TOKEN AUTH --- #######
# Add "qdrant_token_auth" to COMPOSE_PROFILES

# Generate token: openssl rand -base64 32
QDRANT_SECRET_KEY="your-secret-key"

######## HYBRID RETRIEVER ########
HUGGING_FACE_EMBEDDING_NAME="all-MiniLM-L6-v2"
EMBEDDING_SIZE="384"
FAST_EMBED_SPARSE_MODEL_NAME="Qdrant/bm25"

########### OTHER ############
DATABASE_URL="http://localhost:6000/"